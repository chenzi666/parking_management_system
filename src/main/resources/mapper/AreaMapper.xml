<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.parking_management_system.mapper.AreaMapper">

    <resultMap id="AreaResultMap" type="org.example.parking_management_system.entity.Area">
        <id column="id" property="id"/>
        <result column="parking_lot_id" property="parkingLotId"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>
    <resultMap id="AreaDetailsDTOResultMap" type="org.example.parking_management_system.dto.response.AreaDetailsDTO">
        <id column="id" property="areaId"></id>
        <result column="name" property="areaName"></result>
    </resultMap>
    <select id="findByParkingLotId" resultMap="AreaDetailsDTOResultMap">
        SELECT id,name FROM area WHERE parking_lot_id = #{id}
    </select>
    <select id="findByIds" resultMap="AreaResultMap">
        SELECT id, parking_lot_id, name, description, created_at, updated_at FROM area WHERE id IN
            <foreach collection="list" item="item" open="(" close=")" separator=",">
                #{item}
            </foreach>
    </select>
</mapper>