<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.parking_management_system.mapper.ParkingSpaceMapper">

    <resultMap id="ParkingSpaceResultMap" type="org.example.parking_management_system.entity.ParkingSpace">
        <id column="id" property="id"/>
        <result column="parking_lot_id" property="parkingLotId"/>
        <result column="area_id" property="areaId"/>
        <result column="space_number" property="spaceNumber"/>
        <result column="space_type" property="spaceType"/>
        <result column="status" property="status"/>
        <result column="is_monthly" property="isMonthly"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>
    <resultMap id="AreaDetailsDTOResultMap" type="org.example.parking_management_system.dto.response.AreaDetailsDTO">
        <id column="area_id" property="areaId"/>
        <result column="totalSpaces" property="totalSpaces"/>
        <result column="availableSpaces" property="availableSpaces"/>
    </resultMap>

    <select id="totalSpacesCount" resultMap="AreaDetailsDTOResultMap">
        SELECT area_id,COUNT(*) AS totalSpaces
        FROM parking_space
        WHERE area_id IN
        <foreach collection="areaId" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
        GROUP BY area_id
    </select>
    <select id="availableSpacesCount" resultMap="AreaDetailsDTOResultMap">
        SELECT area_id,COUNT(*) AS availableSpaces
        FROM parking_space
        WHERE status = 0 AND area_id IN
        <foreach collection="areaId" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
        GROUP BY area_id
    </select>

    <select id="countOccupiedSpaces" resultType="Integer">
        SELECT COUNT(*) FROM parking_space
        WHERE parking_lot_id = #{parkingLotId} AND status = 1
    </select>

    <select id="countReservedSpaces" resultType="Integer">
        SELECT COUNT(*) FROM parking_space
        WHERE parking_lot_id = #{parkingLotId} AND status = 2
    </select>
</mapper>